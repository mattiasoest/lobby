{
  "name": "lobby",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "prepare": "husky",
    "dev": "concurrently -n web,server -c magenta,cyan \"npm run dev:web\" \"npm run dev:server\"",
    "dev:web": "npm --prefix client run dev",
    "dev:server": "npm --prefix server run dev",
    "build": "npm --prefix client run build",
    "lint": "npm --prefix client run lint",
    "format": "npm --prefix client run format",
    "format:check": "npm --prefix client run format:check",
    "verify:quality": "npm --prefix client run verify:quality"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "husky": "^9.1.7"
  }
}
